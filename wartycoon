    Flag = "CheckRemotesButton",
    Callback = function()
        local status = "ServerBullet: " .. (serverBullet and "FOUND" or "NOT FOUND") .. "\n"
        status = status .. "Hit: " .. (hit and "FOUND" or "NOT FOUND") .. "\n"
        status = status .. "Damage: " .. (damage and "FOUND" or "NOT FOUND")
        Rayfield:Notify({Title = "Remote Status", Content = status, Duration = 4})
    end
})

MainTab:CreateSection("INFO")

MainTab:CreateLabel("1. Enable Silent Aim")
MainTab:CreateLabel("2. Aim near enemy")
MainTab:CreateLabel("3. Shoot normally")
MainTab:CreateLabel("")
MainTab:CreateLabel("If not working, click")
MainTab:CreateLabel("'Check Remotes' and")
MainTab:CreateLabel("tell me what shows")

-- GUI protection
local isGuiActive = false

UserInputService.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.MouseButton2 then
        local mouse = LocalPlayer:GetMouse()
        if mouse.Target and mouse.Target:IsDescendantOf(game:GetService("CoreGui")) then 
            isGuiActive = true 
        end
    end
end)

UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.MouseButton2 then 
        isGuiActive = false 
    end
end)

UserInputService.InputBegan:Connect(function(input)
    if input.KeyCode == Enum.KeyCode.RightControl then 
        restoreServerBullet()
        Rayfield:Destroy() 
    end
end)
